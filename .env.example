# ========== LLM API (OpenAI compatible) ==========
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ========== B站 (可选) ==========
# 浏览器采集器需要登录态，从浏览器 Cookie 获取
BILIBILI_SESSDATA=xxx

# ========== 视觉模型 (可选，B站图片动态识别) ==========
OPENAI_VISION_MODEL=qwen-vl-max
OPENAI_VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_VISION_API_KEY=sk-xxx

# ========== 火山引擎 TTS (可选，视频工作流) ==========
# 旧版控制台: https://console.volcengine.com/speech/service/8
VOLC_TTS_APP_ID=xxx
VOLC_TTS_ACCESS_KEY=xxx
VOLC_TTS_SPEAKER=saturn_zh_female_cancan_tob

# ========== 网络代理 (可选) ==========
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# ========== 时间窗口 ==========
NEWS_WINDOW_DAYS=7
